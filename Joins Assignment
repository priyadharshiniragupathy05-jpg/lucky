create table orders (product_id int, order_status varchar(50) ,shipping_detail varchar(50));
insert into orders value( 101, 'Delivered', 'Banglore'), (102, 'pending', 'chennai'), (105, 'shipped', 'Delhi');

select *from shopping s
left join orders o
on s.product_id = o.product_id;

select *from shopping s
right join orders o
on s.product_id = o.product_id;

select *from shopping s
inner join orders o
on s.product_id = o.product_id;


